# Supabase connection used for durable session storage (see app/persistence.ts).
# Get these from the Supabase dashboard (Project Settings → API) or, in this
# workspace, via the Soda Straw `supabase` straw (get_project_url / get_publishable_keys).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
